          <div className="space-y-4">
            <Link to="/" className="flex items-center gap-2">
              <div className="w-9 h-9 rounded-lg bg-[hsl(var(--royal-blue))] flex items-center justify-center">
                <Code2 className="w-5 h-5 text-[hsl(var(--primary-foreground))]" />
              </div>
              <span className="font-bold text-lg">Divya S</span>
