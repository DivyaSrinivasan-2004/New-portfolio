            <p className="text-muted-foreground text-sm max-w-xs">
              Full-stack developer crafting responsive React frontends and Django/Flask REST backends with calm, reliable delivery.
            </p>
            <div className="flex items-center gap-3">
              {socialLinks.map((social) => (
                <a
