  { icon: Linkedin, href: "https://www.linkedin.com/", label: "LinkedIn" },
  { icon: Twitter, href: "https://x.com/", label: "Twitter" },
  { icon: Mail, href: "mailto:hello@divyas.dev", label: "Email" },
];

